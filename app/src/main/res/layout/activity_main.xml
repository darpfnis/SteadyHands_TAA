<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvStabilityScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="10.0"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="#5C6BC0" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Індекс стабільності"
            android:textColor="@color/black"
            android:alpha="0.6"
            android:textSize="14sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:id="@+id/layoutHomeSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardPostural"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#5C6BC0"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="Почати тест: Тримайте руку максимально рівно"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chart"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutAnalysisSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <Button
                    android:id="@+id/btnToday"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Сьогодні"
                    android:textColor="#5C6BC0"
                    android:textSize="12sp" />

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <ImageButton
                    android:id="@+id/btnSelectDate"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="#5C6BC0" />
            </LinearLayout>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayoutFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                app:tabIndicatorColor="#5C6BC0"
                app:tabIndicatorHeight="3dp"
                app:tabSelectedTextColor="#5C6BC0"
                app:tabTextColor="#757575"
                app:tabRippleColor="#E8EAF6"
                app:tabMode="fixed" />

            <LinearLayout
                android:id="@+id/layoutYearSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="8dp"
                android:background="#FAFAFA"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnPrevYear"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&lt;"
                    android:textColor="#5C6BC0" />



                <TextView
                    android:id="@+id/tvCurrentYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#333"
                    android:layout_marginHorizontal="24dp"/>

                <Button
                    android:id="@+id/btnNextYear"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&gt;"
                    android:textColor="#5C6BC0" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/gridHeatmap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="7"
                android:padding="12dp"
                android:visibility="gone" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:id="@+id/layoutResultCards"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp" />
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutProfileSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvProfileFullName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Користувач"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>
                    <TextView
                        android:id="@+id/tvProfileAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Вік: --"
                        android:layout_marginTop="8dp"/>
                    <TextView
                        android:id="@+id/tvProfileTremor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Стан: --"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button android:id="@+id/btnProfileInfo" android:layout_width="match_parent" android:layout_height="55dp" android:text="ℹ️ Що таке тремор?" android:backgroundTint="#81C784" android:textColor="@color/white" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btnProfileSos" android:layout_width="match_parent" android:layout_height="60dp" android:text="🚨 ПОТРІБНА ДОПОМОГА" android:backgroundTint="#E57373" android:textColor="@color/white" android:textStyle="bold"/>

            <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
            <Button android:id="@+id/btnSettings" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Налаштування" android:backgroundTint="#5C6BC0" android:textColor="@color/white"/>
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/white"
        app:itemIconTint="#5C6BC0"
        app:itemTextColor="#5C6BC0"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>